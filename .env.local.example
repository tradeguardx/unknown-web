ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare Turnstile — anti-bot captcha. Three layered rules gate /start:
#   1. First chat from a fresh IP → always captcha.
#   2. Every CAPTCHA_AFTER_N_CHATS chats since last verify → captcha.
#   3. ~CAPTCHA_RANDOM_RATE of every other chat → captcha (random sample).
# If both keys below are unset, captcha gating is auto-disabled (dev convenience).
#
# Free at https://dash.cloudflare.com/?to=/:account/turnstile
# For local testing without signing up, use Cloudflare's test keys:
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA   (always passes)
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA   (always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# How many chats from a given IP between captcha challenges. Default 10.
# Lower values = more friction but tighter abuse gate. Set to 1 while testing.
CAPTCHA_AFTER_N_CHATS=
# Probability (0–1) that any given chat triggers a random captcha sample.
# Default 0.03 (3%). Set to 0 to disable random sampling entirely.
CAPTCHA_RANDOM_RATE=

# LLM provider switch. Defaults to "anthropic" if unset.
#   anthropic  → Claude Haiku 4.5 (uses ANTHROPIC_API_KEY, prompt caching enabled)
#   deepseek   → deepseek-chat (uses DEEPSEEK_API_KEY, ~3x cheaper than Anthropic)
#   mixed      → 50/50 coin-flip per SESSION (each chat commits to one provider
#                for its full lifetime). Adds variance — different model voice
#                per chat. Both ANTHROPIC_API_KEY and DEEPSEEK_API_KEY must be set.
LLM_PROVIDER=anthropic

# DeepSeek — used for chat (when LLM_PROVIDER=deepseek) AND for the rolling
# user-memory extractor (always, regardless of LLM_PROVIDER, if the key is set).
# Set this even when running Claude for chat — memory extraction needs it.
# Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# Override default DeepSeek chat model. Defaults to deepseek-chat (V3).
# Other option: deepseek-reasoner (R1, more expensive, reasoning-tuned).
DEEPSEEK_MODEL=
# Override the model used for memory extraction. Defaults to deepseek-chat.
# If DEEPSEEK_API_KEY isn't set, memory extraction is silently disabled and
# chat works without rolling memory.
DEEPSEEK_EXTRACT_MODEL=

# Cap conversation history sent to the LLM (cost control + reasonable persona memory).
# Default 20 = ~10 back-and-forth turns. System prompt + prefs are always sent in full
# regardless. Bump to 30-40 for longer-memory chats; drop to 10 for tighter cost.
HISTORY_LIMIT=

# How often to refresh the rolling user-memory (in total message count).
# Default 10. Set higher for less frequent (cheaper) refreshes.
MEMORY_REFRESH_EVERY=

# Plausible Analytics — privacy-friendly, cookie-free analytics.
# Sign up at https://plausible.io. Two values you need:
#
# 1. The domain you registered in Plausible (used for server-side events).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# 2. The per-site tracker script URL (shown on Plausible's install page —
#    looks like https://plausible.io/js/pa-XXXXXXXXXXXX.js). Required for
#    the client-side tracker to load. The legacy /js/script.js + data-domain
#    form still works briefly but is being sunset.
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=
# Optional override if you self-host Plausible Community Edition.
# Defaults to https://plausible.io
PLAUSIBLE_API_HOST=
