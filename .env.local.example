ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare Turnstile — anti-bot CAPTCHA shown every 5 chats.
# Free at https://dash.cloudflare.com/?to=/:account/turnstile
# If both are unset, captcha gating is automatically disabled (dev convenience).
#
# For local testing without signing up, you can use Cloudflare's test keys:
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA   (always passes)
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA   (always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# LLM provider switch. Defaults to "anthropic" if unset.
#   anthropic   → Claude Haiku 4.5 (uses ANTHROPIC_API_KEY, prompt caching enabled)
#   groq        → Llama 3.3 70B Versatile (uses GROQ_API_KEY, fast + generous free tier)
LLM_PROVIDER=anthropic

# Groq — fast inference, generous free tier (30 RPM, 100k req/day on llama-3.3-70b).
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Override default Groq model. Defaults to llama-3.3-70b-versatile.
# Other options: llama-3.1-8b-instant (faster but smaller), openai/gpt-oss-120b
GROQ_MODEL=
